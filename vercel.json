{
  "version": 2,
  "builds": [
    {
      "src": "server/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/icon.png",
      "headers": { "Cache-Control": "no-store" }
    },
    {
      "src": "/splash.png",
      "headers": { "Cache-Control": "no-store" }
    },
    {
      "src": "/hero.png",
      "headers": { "Cache-Control": "no-store" }
    },
    {
      "src": "/api/ping",
      "dest": "/server/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ]
}
